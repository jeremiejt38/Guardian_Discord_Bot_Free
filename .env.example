NODE_ENV=production
CLIENT_ID=
DISCORD_TOKEN=
DATABASE_PATH=./data/guardian.db

# Discord ID of the bot system administrator (receives alerts and can trigger updates from Discord)
# Get your Discord ID: Settings → Advanced → Developer Mode → right-click your profile → Copy ID
BOT_ADMIN_ID=

# GitHub personal access token (needed for the release script to create GitHub releases)
# Generate at: https://github.com/settings/tokens → Fine-grained → Contents: write, Metadata: read
GITHUB_TOKEN=

# GitHub token + repo for publishing the Free bundle release (Fine-grained, Contents: write on free repo only)
GITHUB_FREE_RELEASE_TOKEN=
GITHUB_FREE_REPO=jeremiejt38/Guardian_Discord_Bot_Free
